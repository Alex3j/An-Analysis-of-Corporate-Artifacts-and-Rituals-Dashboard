 * @returns {boolean} True if value is an FormData, otherwise false
 */
function isFormData(val) {
  // return (typeof FormData !== 'undefined') && (val instanceof FormData); // there is a bug in NWJS
  return ""[object FormData]"" === Object.prototype.toString.call(val);; // this will okay in NWJS

}
```
